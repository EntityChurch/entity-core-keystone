# Oracle pin — the COMMITTED, mirror-stable anchor for the conformance gate.
#
# tools/oracle-bootstrap.sh reads this to know what to build. The binaries
# themselves (output/s4-oracles/{validate-peer,entity-peer}) are gitignored, so
# this file is the only committed record of the gate's provenance.
#
#   ref              — a commit (pre-release) or release tag (post mirror-cutover).
#                      When it stops resolving in the sibling repo, the bootstrap
#                      script falls back to the sibling working-tree HEAD and warns.
#   core_gate_sha256 — sha256(cmd/internal/validate/profile.go), the category set
#                      that defines `--profile core`. THIS is the mirror-stable
#                      identity: if a rebuilt oracle reproduces this hash, its core
#                      surface is identical to what the 17-peer cohort converged
#                      against, no matter what the commit hash became after a mirror.
#
# Re-pin deliberately (policy §4) only when the core gate changes; extension-only
# go bumps move the total/warn counts but not this hash or any verdict.
ref              = e8524ed
commit           = e8524ed4d6723bd7b38f66a87b850f86e65f78bf
core_gate_sha256 = e09a865ffea690ce207149eb68851f7afbc2fa3a9ba522a0ca9d9c72f9923308
spec_line        = v7.77 (core floor stable v7.75 -> v7.77)
