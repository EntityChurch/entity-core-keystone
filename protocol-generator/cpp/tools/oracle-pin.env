# Oracle pin for entity-core-protocol-cpp conformance (S4/S5).
#
# The validate-peer / entity-peer Go oracle is built from a read-only `git archive`
# extract of the READ-ONLY entity-core-go source at this commit, OUTSIDE the go repo
# (CGO_ENABLED=0, GOWORK=off, in the go-toolchain image). The oracle ELF is gitignored
# (a local tool); this file pins its provenance + the core-gate hash so a rebuild is
# verifiable. See status/CONFORMANCE-REPORT.md for the rebuild runbook.
#
# v7.77 cohort baseline (go HEAD; the core category set in profile.go is byte-unchanged
# v7.75->v7.77 — the v7.77 delta is entirely extension + the V8-naming kebab fold).

ORACLE_REPO=entity-core-go
ORACLE_COMMIT=e8524ed
ORACLE_SPEC_VERSION=v7.77
# sha256 of the compiled core-gate category set (profile.go coreProfileCategories);
# run-s4 / the conformance report assert this matches the committed value.
CORE_GATE_SHA256=e09a865ffea690ce207149eb68851f7afbc2fa3a9ba522a0ca9d9c72f9923308

# Codec fixture provenance (S2): wire-conformance build-fixture at go HEAD 71b6ba8 emits
# conformance-vectors-v1.cbor byte-identical to the vendored corpus (sha 41d68d2d...).
WIRE_CONFORMANCE_COMMIT=71b6ba8
CODEC_CORPUS_VERSION=v7.71
CODEC_CORPUS_SHA256_PREFIX=41d68d2d
