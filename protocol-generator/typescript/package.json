{
  "name": "entity-core-protocol-typescript",
  "version": "0.1.0",
  "description": "Entity Core Protocol peer (V7 Layers 0-4) in TypeScript. Generated by entity-core-keystone /entity-rosetta. Browser-portable codec + crypto core; Node transport.",
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./codec": {
      "types": "./dist/src/codec/index.d.ts",
      "import": "./dist/src/codec/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test \"dist/test/**/*.test.js\"",
    "conformance": "node dist/test/run-conformance.js"
  },
  "dependencies": {
    "@noble/curves": "2.2.0",
    "@noble/hashes": "2.2.0"
  },
  "devDependencies": {
    "@types/node": "24.12.3",
    "cborg": "5.1.1",
    "typescript": "5.8.3"
  }
}
