# frozen_string_literal: true

source "https://rubygems.org"

# Core peer has ZERO runtime gem deps (crypto/hashing = stdlib openssl/digest;
# CBOR/base58/varint hand-rolled). The only dev-time tools — Minitest + Rake —
# ship with Ruby as DEFAULT gems; they are declared here so `bundle exec rake`
# can find them, and registered into the bundle in the one network-on
# `bundle install` step (the [container].network_policy = pull-once-then-offline
# posture). After that, `bundle install --local` / `--network=none` resolves
# them from `/usr/local/bundle`.
gemspec

group :development do
  # Pinned to the versions Ruby 3.4.4 ships as DEFAULT gems (already present in
  # the base image), so Bundler resolves them from the system gem set with no
  # network fetch — keeping the pull-once-then-offline posture honest.
  gem "minitest", "~> 5.25"
  gem "rake", "~> 13.2"
end
